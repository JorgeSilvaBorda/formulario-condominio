{
  "name": "formulario-condominio",
  "version": "1.0.0",
  "private": true,
  "description": "Aplicación web/NW.js para formularios y registro de datos.",
  "keywords": [
    "nwjs",
    "formulario",
    "desktop"
  ],
  "homepage": "https://github.com/JorgeSilvaBorda/formulario-condominio#readme",
  "bugs": {
    "url": "https://github.com/JorgeSilvaBorda/formulario-condominio/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JorgeSilvaBorda/formulario-condominio.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.html",
  "scripts": {
    "start": "nw .",
    "build": "node compilar.js",
    "clean": "node -e \"const fs=require('fs'); ['dist','app.nw'].forEach((file)=>fs.rmSync(file,{recursive:true,force:true}));\""
  },
  "devDependencies": {
    "archiver": "^5.3.2",
    "nw": "^0.112.0-sdk",
    "nw-builder": "^4.17.13",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18"
  },
  "window": {
    "width": 1024,
    "min_width": 1024,
    "height": 768,
    "min_height": 768
  },
  "allowScripts": {
    "nw@0.112.0-sdk": true,
    "xlsx@0.18.5": true
  }
}
